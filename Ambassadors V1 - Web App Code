}

function buildUpzone(type) {
  const cfgs = {
    ine:     {done:S.ineOk,  load:S.ineL,  icon:'bi-person-vcard-fill', label:'INE / IFE',           doneLabel:'INE ✓', sub:'JPG, PNG o PDF'},
    bank:    {done:S.bankOk, load:S.bankL, icon:'bi-bank',              label:'Estado de cuenta',    doneLabel:'Estado de cuenta ✓', sub:'PDF o imagen'},
    dom_doc: {done:S.domOk,  load:S.domL,  icon:'bi-house-door-fill',   label:'Comp. domicilio',     doneLabel:'Domicilio ✓', sub:'PDF o imagen'},
  };
  const cfg = cfgs[type];
  const el = h('div', {class: 'upzone' + (cfg.done ? ' done' : cfg.load ? ' loading' : '')});
  el.addEventListener('click', function() {
    if (cfg.load) return;
    const fi = document.createElement('input'); fi.type = 'file'; fi.accept = 'image/*,.pdf';
    fi.onchange = function(e) { if (e.target.files[0]) loadFile(type, e.target.files[0]); };
    fi.click();
  });
  const iconEl = h('div', {class: 'upzone-icon', style: {
    background: cfg.done ? 'var(--gl)' : cfg.load ? 'var(--fm)' : 'var(--n100)',
    color: cfg.done ? 'var(--gd)' : cfg.load ? 'var(--aq)' : 'var(--n400)'
  }});
  if (cfg.load) iconEl.innerHTML = '<div class="spin" style="width:22px;height:22px;border:2.5px solid #EBEDF0;border-top-color:#4AC9E3"></div>';
  else if (cfg.done) iconEl.innerHTML = '<i class="bi bi-check-circle-fill" style="font-size:24px"></i>';
  else iconEl.innerHTML = '<i class="bi ' + cfg.icon + '" style="font-size:24px"></i>';
  const lbl = h('div', {class: 'upzone-label', style: {color: cfg.done ? 'var(--gd)' : 'var(--t2)'}});
  lbl.textContent = cfg.load ? 'Subiendo...' : (cfg.done ? cfg.doneLabel : cfg.label);
  const sub = h('div', {class: 'upzone-sub'});
  sub.textContent = cfg.sub;
  el.appendChild(iconEl); el.appendChild(lbl); el.appendChild(sub);
  return el;
}

function loadFile(type, file) {
  if (type === 'ine') S.ineL = true;
  else if (type === 'bank') S.bankL = true;
  else if (type === 'dom_doc') S.domL = true;
  render();
  const r = new FileReader();
  r.onload = function(e) {
    const b64 = e.target.result.split(',')[1];
    const mime = file.type.startsWith('image/') ? file.type : 'application/pdf';
    if (type === 'ine')      { S.D.ineB64 = b64; S.D.ineMime = mime; S.ineL = false; S.ineOk = true; }
    else if (type === 'bank')    { S.D.bankB64 = b64; S.D.bankMime = mime; S.bankL = false; S.bankOk = true; }
    else if (type === 'dom_doc') { S.D.domB64 = b64; S.D.domMime = mime; S.domL = false; S.domOk = true; }
    render();
  };
  r.readAsDataURL(file);
}

function s2next() {
  var req = ['nin','rfc','banco','cuenta','clabe','titular','dom'];
  var missing = req.filter(function(k) { return !S.D[k] || !S.D[k].trim(); });
  if (missing.length) { alert('Por favor completa todos los campos requeridos.'); return; }
  if ((S.D.clabe||'').length !== 18) { alert('La CLABE debe tener exactamente 18 dígitos.'); return; }
  if (!S.ineOk)  { alert('Por favor sube tu INE / IFE.'); return; }
  if (!S.bankOk) { alert('Por favor sube tu estado de cuenta.'); return; }
  if (!S.domOk)  { alert('Por favor sube tu comprobante de domicilio.'); return; }
  go(3);
}

