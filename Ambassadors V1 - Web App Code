function getConfig() {
  const props = PropertiesService.getScriptProperties();
  return {
    anthropicKey: props.getProperty('ANTHROPIC_API_KEY') || '',
    adminEmail:   props.getProperty('ADMIN_EMAIL') || 'team@aplazo.mx',
    folderId:     props.getProperty('DRIVE_FOLDER_ID') || '',
    sheetId:      props.getProperty('SHEET_ID') || '',
  };
}

function doGet(e) {
  return HtmlService
    .createHtmlOutput(getAppHTML())
    .setTitle('Aplazo — Programa Embajadores')
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL)
    .addMetaTag('viewport', 'width=device-width, initial-scale=1');
}

function doPost(e) {
  const cors = ContentService.createTextOutput();
  cors.setMimeType(ContentService.MimeType.JSON);
  try {
    const payload = JSON.parse(e.postData.contents);
    if (payload.action === 'submit') {
      const result = handleSubmission(payload);
      cors.setContent(JSON.stringify({ ok: true, regId: result.regId }));
      return cors;
    }
    cors.setContent(JSON.stringify({ ok: false, error: 'Unknown action' }));
  } catch(err) {
    cors.setContent(JSON.stringify({ ok: false, error: err.message }));
  }
  return cors;
}

function getBlankContractForBrowser() { return getContractPDFBase64(); }

function submitRegistration(dataJson) {
  const payload = JSON.parse(dataJson);
  return handleSubmission(payload);
}

function b64ToBlob_(b64String, mimeType, filename) {
  const clean = b64String.replace(/\s/g, '');
  const bytes  = Utilities.base64Decode(clean);
  return Utilities.newBlob(bytes, mimeType, filename);
}

