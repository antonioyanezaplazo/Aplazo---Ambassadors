function saveContractToStorage(argsJson) {
  const args = JSON.parse(argsJson);
  const { regId, contractB64, nom, ap, email } = args;
  const cfg = getConfig();
  if (!contractB64 || !regId) return { ok: false };
  try {
    const safeName = (nom + '_' + ap).replace(/[^a-zA-Z0-9_]/g, '_').substring(0, 40);
    const blob = b64ToBlob_(contractB64, 'application/pdf', 'Contrato_' + safeName + '_' + regId + '.pdf');
    let contractUrl = '', fileId = '';
    const folderId = (cfg.folderId || '').trim();
    if (folderId) {
      try {
        const folder = DriveApp.getFolderById(folderId);
        let sub = null;
        const iter = folder.getFolders();
        while (iter.hasNext()) { const f = iter.next(); if (f.getName().indexOf(regId) === 0) { sub = f; break; } }
        if (!sub) sub = folder.createFolder(regId + ' — ' + nom + ' ' + ap);
        const cf = sub.createFile(blob);
        contractUrl = cf.getUrl(); fileId = cf.getId();
      } catch(driveErr) { Logger.log('saveContractToStorage Drive error: ' + driveErr.message); }
    }
    if (cfg.sheetId && contractUrl) {
      try {
        const sheet = SpreadsheetApp.openById(cfg.sheetId).getSheetByName('Registros');
        if (sheet) {
          const vals = sheet.getRange(1, 1, sheet.getLastRow(), 1).getValues();
          for (let i = 1; i < vals.length; i++) { if (vals[i][0] === regId) { sheet.getRange(i+1, 19).setValue(contractUrl); break; } }
        }
      } catch(sheetErr) { Logger.log('saveContractToStorage Sheet error: ' + sheetErr.message); }
    }
    return { ok: true, contractUrl };
  } catch(fatalErr) {
    Logger.log('saveContractToStorage fatal: ' + fatalErr.message);
    return { ok: false };
  }
}

// ── Helper: get mime extension without shadowing catch variable ──
function getMimeExt_(mime) {
  return (mime || '').toLowerCase().indexOf('pdf') >= 0 ? 'pdf' : 'jpg';
}

function handleSubmission(payload) {
  const cfg   = getConfig();
  const regId = 'EMB-' + new Date().getTime().toString(36).toUpperCase();
  const ts    = new Date().toLocaleString('es-MX', { timeZone:'America/Mexico_City' });

  // Trim the folder ID — whitespace is the #1 silent killer
  const folderId = (cfg.folderId || '').trim();
  Logger.log('handleSubmission START — regId: ' + regId + ' | folderId set: ' + (folderId ? 'YES ('+folderId.length+' chars)' : 'NO'));

  // ── Decode contract PDF ──────────────────────────────────────────
  let contractPdfBlob = null, contractPdfBytes = null;
  if (payload.contractB64 && payload.contractB64.length > 100) {
    try {
      const safeName = (payload.nom + '_' + payload.ap).replace(/[^a-zA-Z0-9_]/g, '_').substring(0, 40);
      contractPdfBlob  = b64ToBlob_(payload.contractB64, 'application/pdf', 'Contrato_' + safeName + '_' + regId + '.pdf');
      contractPdfBytes = contractPdfBlob.getBytes();
      Logger.log('Contract decoded OK — ' + contractPdfBytes.length + ' bytes');
    } catch(decodeErr) {
      Logger.log('Contract decode FAILED: ' + decodeErr.message);
      contractPdfBlob = null; contractPdfBytes = null;
    }
  } else {
    Logger.log('No contractB64 in payload');
  }

  // ── Drive: create subfolder + upload each file independently ────
  let driveLinks = {};

  if (!folderId) {
    Logger.log('⚠️ DRIVE_FOLDER_ID is empty — skipping all Drive uploads. Set it in Script Properties.');
  } else {
    // Step 1: Get parent folder
    let parentFolder = null;
    try {
      parentFolder = DriveApp.getFolderById(folderId);
      Logger.log('Parent folder OK: ' + parentFolder.getName());
    } catch(folderErr) {
      Logger.log('❌ Cannot open parent folder [' + folderId + ']: ' + folderErr.message);
    }

    // Step 2: Create ambassador subfolder
    let sub = null;
    if (parentFolder) {
      try {
        const subName = regId + ' — ' + (payload.nin || payload.nom || 'Embajador');
        sub = parentFolder.createFolder(subName);
        Logger.log('Subfolder created: ' + subName);
      } catch(subErr) {
        Logger.log('❌ Cannot create subfolder: ' + subErr.message);
      }
    }

    // Step 3: Upload each file — each in its own try/catch, NO shared variable names
    if (sub) {
      // INE
      if (payload.ineB64 && payload.ineB64.length > 10) {
        try {
          const ineExt  = getMimeExt_(payload.ineMime);
          const ineMime = payload.ineMime || 'image/jpeg';
          const ineBlob = b64ToBlob_(payload.ineB64, ineMime, 'INE.' + ineExt);
          const ineFile = sub.createFile(ineBlob);
          driveLinks.ine = ineFile.getUrl();
          Logger.log('✅ INE uploaded: ' + driveLinks.ine);
        } catch(ineErr) { Logger.log('❌ INE upload failed: ' + ineErr.message); }
      } else { Logger.log('INE b64 missing or empty'); }

      // Bank statement
      if (payload.bankB64 && payload.bankB64.length > 10) {
        try {
          const bankExt  = getMimeExt_(payload.bankMime);
          const bankMime = payload.bankMime || 'image/jpeg';
          const bankBlob = b64ToBlob_(payload.bankB64, bankMime, 'EstadoCuenta.' + bankExt);
          const bankFile = sub.createFile(bankBlob);
          driveLinks.bank = bankFile.getUrl();
          Logger.log('✅ Bank statement uploaded: ' + driveLinks.bank);
        } catch(bankErr) { Logger.log('❌ Bank upload failed: ' + bankErr.message); }
      } else { Logger.log('Bank b64 missing or empty'); }

      // Proof of address
      if (payload.domB64 && payload.domB64.length > 10) {
        try {
          const domExt  = getMimeExt_(payload.domMime);
          const domMime = payload.domMime || 'image/jpeg';
          const domBlob = b64ToBlob_(payload.domB64, domMime, 'ComprobanteDomicilio.' + domExt);
          const domFile = sub.createFile(domBlob);
          driveLinks.domDoc = domFile.getUrl();
          Logger.log('✅ Domicilio uploaded: ' + driveLinks.domDoc);
        } catch(domErr) { Logger.log('❌ Domicilio upload failed: ' + domErr.message); }
      } else { Logger.log('Domicilio b64 missing or empty'); }

      // Signed contract PDF
      if (contractPdfBytes && contractPdfBytes.length > 0) {
        try {
          const contractBlob = Utilities.newBlob(contractPdfBytes, 'application/pdf', contractPdfBlob.getName());
          const contractFile = sub.createFile(contractBlob);
          driveLinks.contract       = contractFile.getUrl();
          driveLinks.contractFileId = contractFile.getId();
          Logger.log('✅ Contract PDF uploaded: ' + driveLinks.contract);
        } catch(contractErr) { Logger.log('❌ Contract PDF upload failed: ' + contractErr.message); }
      } else { Logger.log('No contract bytes to upload'); }

    } else {
      Logger.log('⚠️ Subfolder is null — all Drive uploads skipped');
    }
  }

  if (cfg.sheetId) {
    try {
      const ss = SpreadsheetApp.openById(cfg.sheetId);
      const sheet = ss.getSheetByName('Registros') || ss.insertSheet('Registros');
      const H = ['RegID','Timestamp','Nombre INE','Nombre','Apellido','RFC','Email','Tel','Ciudad','Banco','Cuenta','CLABE','Titular','Domicilio','Fuente','Drive INE','Drive Banco','Drive Comp Dom','Drive Contrato'];
      if (sheet.getLastRow() === 0) sheet.appendRow(H);
      else if (sheet.getRange(1,1).getValue() !== 'RegID') { sheet.insertRowBefore(1); sheet.getRange(1,1,1,H.length).setValues([H]); }
      sheet.appendRow([regId,ts,payload.nin,payload.nom,payload.ap,payload.rfc,payload.email,payload.tel,payload.ciudad,payload.banco,payload.cuenta,payload.clabe,payload.titular,payload.domicilio||payload.dom||'',payload.fuente||'',driveLinks.ine||'',driveLinks.bank||'',driveLinks.domDoc||'',driveLinks.contract||'']);
    } catch(err) { Logger.log('Sheet error: ' + err.message); }
  }

  try {
    let cBlob = null;
    if (driveLinks.contractFileId) { try { cBlob = DriveApp.getFileById(driveLinks.contractFileId).getBlob(); } catch(e){} }
    if (!cBlob && contractPdfBytes) { try { cBlob = Utilities.newBlob(contractPdfBytes,'application/pdf','Contrato_'+regId+'.pdf'); } catch(e){} }
    MailApp.sendEmail({ to:cfg.adminEmail, subject:'[Embajador] Nuevo registro: '+payload.nom+' '+payload.ap+' — '+regId, htmlBody:buildAdminEmail(regId,ts,payload,driveLinks), attachments:cBlob?[cBlob]:[] });
  } catch(err) { Logger.log('Admin email: ' + err.message); }

  if (payload.email) {
    try {
      let cBlob = null;
      if (driveLinks.contractFileId) { try { cBlob = DriveApp.getFileById(driveLinks.contractFileId).getBlob(); } catch(e){} }
      if (!cBlob && contractPdfBytes) { try { cBlob = Utilities.newBlob(contractPdfBytes,'application/pdf','Contrato_Aplazo_'+regId+'.pdf'); } catch(e){} }
      MailApp.sendEmail({ to:payload.email, subject:'¡Bienvenido al Programa Embajadores Aplazo! — '+regId, htmlBody:buildAmbassadorEmail(regId,payload), attachments:cBlob?[cBlob]:[] });
    } catch(err) { Logger.log('Amb email: ' + err.message); }
  }

  return { regId };
}

