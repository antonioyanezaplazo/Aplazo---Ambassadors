};

const STEPS = ['','Tus datos','Documentos','Verificar','Contrato','¡Listo!'];

function render() {
  renderStepper();
  const app = document.getElementById('app');
  app.innerHTML = '';
  const el = buildStep(S.step);
  app.appendChild(el);
  el.style.animation = 'fadeUp .35s ease both';
}

function renderStepper() {
  const el = document.getElementById('stepper');
  el.innerHTML = '';
  [1,2,3,4,5].forEach(function(i) {
    const dot = document.createElement('div');
    dot.className = 's-dot';
    if (i < S.step) {
      dot.style.cssText = 'background:#4AC9E3;color:#214345;box-shadow:0 0 0 3px rgba(74,201,227,.2)';
      dot.innerHTML = '<i class="bi bi-check" style="font-size:12px;font-weight:900"></i>';
    } else if (i === S.step) {
      dot.style.cssText = 'background:#214345;color:#fff;box-shadow:0 0 0 4px rgba(74,201,227,.2)';
      dot.textContent = i;
    } else {
      dot.style.cssText = 'background:#EBEDF0;color:#8FA0AC;border:1.5px solid #E2E5E8';
      dot.textContent = i;
    }
    const lbl = document.createElement('span');
    lbl.className = 's-label';
    lbl.style.color = i < S.step ? '#357A09' : i === S.step ? '#214345' : '#7F8D98';
    lbl.textContent = STEPS[i];
    el.appendChild(dot);
    el.appendChild(lbl);
    if (i < 5) {
      const line = document.createElement('div');
      line.className = 's-line';
      line.style.background = i < S.step ? '#4AC9E3' : '#E2E5E8';
      el.appendChild(line);
    }
  });
}

function go(n) {
  S.step = n;
  document.getElementById('registro').scrollIntoView({ behavior: 'smooth', block: 'start' });
  render();
}

function buildStep(n) {
  var fns = {1:buildStep1, 2:buildStep2, 3:buildStep3, 4:buildStep4, 5:buildStep5};
  return fns[n]();
}

function h(tag, attrs, children) {
  attrs = attrs || {}; children = children || [];
  const el = document.createElement(tag);
  Object.keys(attrs).forEach(function(k) {
    var v = attrs[k];
    if (k === 'style' && typeof v === 'object') Object.assign(el.style, v);
    else if (k === 'class') el.className = v;
    else if (k === 'onClick') el.addEventListener('click', v);
    else el.setAttribute(k, v);
  });
  children.forEach(function(c) {
    if (typeof c === 'string') el.appendChild(document.createTextNode(c));
    else if (c) el.appendChild(c);
  });
  return el;
}

function fld(label, hint, child, span) {
  const d = h('div', {class: 'fld' + (span ? ' span2' : '')});
  d.appendChild(h('label', {}, [label]));
  d.appendChild(child);
  if (hint) d.appendChild(h('span', {class: 'hint'}, [hint]));
  return d;
}

function inp(id, placeholder, type, opts) {
  type = type || 'text'; opts = opts || {};
  const el = document.createElement('input');
  el.id = id; el.placeholder = placeholder; el.type = type;
  if (opts.maxLength) el.maxLength = opts.maxLength;
  el.value = S.D[id] || '';
  if (S.errs[id]) el.classList.add('err');
  el.addEventListener('input', function(e) { S.D[id] = e.target.value; S.errs[id] = false; e.target.classList.remove('err'); });
  return el;
}

// ── STEP 1 ──
