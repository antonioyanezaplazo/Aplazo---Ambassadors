    const t = h('div',{style:{display:'flex',alignItems:'center',gap:'6px',fontSize:'12px',color:'var(--t3)',fontWeight:'600'}});
    t.innerHTML = '<i class="bi '+item[0]+'" style="color:var(--cy)"></i> '+item[1];
    trust.appendChild(t);
  });
  wrap.appendChild(trust);

  const nav = h('div', {class: 'form-nav'});
  nav.appendChild(h('span', {}));
  const btn = h('button', {class: 'btn btn-primary', onClick: s1next});
  btn.innerHTML = 'Continuar <i class="bi bi-arrow-right"></i>';
  nav.appendChild(btn);
  wrap.appendChild(nav);
  return wrap;
}

function s1next() {
  ['nom','ap','tel','email','ciudad'].forEach(function(id) {
    var el = document.getElementById(id); if (el) S.D[id] = el.value;
  });
  var sel = document.querySelector('select'); if (sel) S.D.fuente = sel.value;
  const e = {};
  if (!S.D.nom||!S.D.nom.trim()) e.nom = 1;
  if (!S.D.ap||!S.D.ap.trim()) e.ap = 1;
  if (!S.D.tel||S.D.tel.length < 8) e.tel = 1;
  var em = S.D.email || '';
  if (em.indexOf('@') < 1 || em.indexOf('.') < 0 || em.length < 5) e.email = 1;
  if (!S.D.ciudad||!S.D.ciudad.trim()) e.ciudad = 1;
  S.errs = e;
  if (!Object.keys(e).length) go(2); else render();
}

// ── STEP 2 ──
function buildStep2() {
  const wrap = h('div', {});

  // Upload card
  const ucard = h('div', {class: 'fcard'});
  const uhdr = h('div', {class: 'fcard-header'});
