function doSign() {
  showOverlay('Firmando tu contrato...', 'Generando documento oficial personalizado');
  S.gen = true;
  if (!CONTRACT_B64 || CONTRACT_B64.length < 100) { doSubmitToServer(S.D); return; }
  if (!window.PDFLib) {
    showOverlay('Cargando librerías...', 'Un momento por favor');
    var waited = 0;
    var interval = setInterval(function() {
      waited += 200;
      if (window.PDFLib) { clearInterval(interval); runPdfFill(CONTRACT_B64); }
      else if (waited >= 8000) { clearInterval(interval); doSubmitToServer(S.D); }
    }, 200);
    return;
  }
  runPdfFill(CONTRACT_B64);
}

function b64Encode(bytes) {
  var CHUNK = 3 * 1024;
  var result = '';
  for (var i = 0; i < bytes.length; i += CHUNK) {
    var slice = bytes.subarray(i, i + CHUNK);
    result += btoa(String.fromCharCode.apply(null, slice));
  }
  return result;
}

function runPdfFill(blankB64) {
  var today = new Date().toLocaleDateString('es-MX', {day:'2-digit', month:'long', year:'numeric'});
  var signer = S.D.nin || (S.D.nom + ' ' + S.D.ap);
  var raw = Uint8Array.from(atob(blankB64), function(c){ return c.charCodeAt(0); });
  PDFLib.PDFDocument.load(raw, {ignoreEncryption:true}).then(function(doc) {
    return Promise.all([
      doc.embedFont(PDFLib.StandardFonts.TimesRoman),
      doc.embedFont(PDFLib.StandardFonts.TimesRomanBold)
    ]).then(function(fonts) {
      var font = fonts[0]; var fontBold = fonts[1];
      var pages = doc.getPages();
      var p1 = pages[0]; var p8 = pages[7];
      var black = PDFLib.rgb(0,0,0); var white = PDFLib.rgb(1,1,1);
      var h1 = p1.getHeight(); var fs = 9;
      function t(pg, x, y, val) { if (val) pg.drawText(String(val), {x:x, y:pg.getHeight()-y, size:fs, font:font, color:black}); }
      function tBold(pg, x, y, val, sz) { if (val) pg.drawText(String(val), {x:x, y:pg.getHeight()-y, size:sz||11, font:fontBold, color:black}); }
      t(p1,110,218,signer); t(p1,98,231,S.D.rfc||''); t(p1,120,244,S.D.domicilio||S.D.dom||'');
      t(p1,172,257,S.D.email||''); t(p1,176,270,S.D.clabe||''); t(p1,100,283,S.D.banco||'');
      t(p1,106,296,S.D.cuenta||''); t(p1,150,309,today);
      p1.drawRectangle({x:406, y:h1-502, width:125, height:16, color:white});
      tBold(p1,360,534,signer,10); tBold(p8,360,634,signer,10);
      return doc.save();
    });
  }).then(function(bytes) {
    S.contractBytes = bytes;
    S.contractB64filled = b64Encode(bytes);
    var data = JSON.parse(JSON.stringify(S.D));
    data.contractB64 = S.contractB64filled;
    doSubmitToServer(data);
  }).catch(function(err) {
    console.error('PDF fill error:', err.message || err);
    doSubmitToServer(S.D);
  });
}

function doSubmitToServer(data) {
  showOverlay('Enviando registro...', 'Guardando documentos y contrato en Drive');
  google.script.run
    .withSuccessHandler(function(result) {
      var rid = result.regId || ('EMB-' + Date.now().toString(36).toUpperCase());
      S.rid = rid;
      S.summ = [['ID de embajador', rid], ['Nombre', S.D.nom + ' ' + S.D.ap],
                ['RFC', S.D.rfc], ['CLABE', S.D.clabe],
                ['Comisión por activación', '$250 MXN'], ['Vigencia del contrato', '2 meses']];
      S.gen = false; hideOverlay(); go(5);
    })
    .withFailureHandler(function(err) {
      S.gen = false; hideOverlay();
      alert('Error al procesar: ' + err.message);
    })
    .submitRegistration(JSON.stringify(data));
}

